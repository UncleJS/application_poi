[Unit]
Description=POI Web service
BindsTo=poi-pod.service
After=poi-pod.service poi-api.service
Requires=poi-api.service

[Container]
ContainerName=poi-web
Image=localhost/poi-web:latest
Pod=poi.pod
EnvironmentFile=__PROJECT_ROOT__/.runtime/poi.env

[Service]
Restart=always
TimeoutStartSec=120

[Install]
WantedBy=poi-pod.service
