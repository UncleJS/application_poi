{
  "openapi": "3.1.0",
  "info": {
    "title": "POI API",
    "version": "2.0.0",
    "description": "Per-user POI API with ACL sharing, admin user/category management, archive/restore lifecycle, and MariaDB photo storage"
  },
  "servers": [
    {
      "url": "http://localhost:9010"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/ready": {
      "get": {
        "summary": "Readiness check",
        "responses": { "200": { "description": "Ready" } }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Login and get token pair",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Token pair" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/auth/refresh": {
      "post": {
        "summary": "Refresh token pair",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Refreshed" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/api/admin/users": {
      "get": {
        "summary": "List users (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "includeArchived", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": { "200": { "description": "User list" }, "403": { "description": "Forbidden" } }
      },
      "post": {
        "summary": "Create user (admin)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password", "role"],
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "role": { "type": "string", "enum": ["admin", "user"] }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" }, "409": { "description": "Conflict" } }
      }
    },
    "/api/admin/users/{id}": {
      "patch": {
        "summary": "Update user role/password (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Updated" }, "403": { "description": "Forbidden" } }
      },
      "delete": {
        "summary": "Archive user (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Archived" } }
      }
    },
    "/api/admin/users/{id}/restore": {
      "post": {
        "summary": "Restore user (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Restored" } }
      }
    },
    "/api/categories": {
      "get": {
        "summary": "List categories",
        "parameters": [
          { "name": "includeArchived", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": { "200": { "description": "Category list" } }
      }
    },
    "/api/admin/categories": {
      "post": {
        "summary": "Create category (admin)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" }, "403": { "description": "Forbidden" }, "409": { "description": "Conflict" } }
      }
    },
    "/api/admin/categories/{id}": {
      "patch": {
        "summary": "Update category name (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated" }, "403": { "description": "Forbidden" }, "409": { "description": "Conflict" } }
      },
      "delete": {
        "summary": "Archive category (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Archived" }, "403": { "description": "Forbidden" }, "409": { "description": "Category in use" } }
      }
    },
    "/api/admin/categories/{id}/restore": {
      "post": {
        "summary": "Restore category (admin)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Restored" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/pois": {
      "get": {
        "summary": "List/search accessible POIs",
        "parameters": [
          { "name": "categoryId", "in": "query", "schema": { "type": "string" } },
          { "name": "q", "in": "query", "schema": { "type": "string" } },
          { "name": "scope", "in": "query", "schema": { "type": "string", "enum": ["all", "mine", "shared"] } },
          { "name": "includeArchived", "in": "query", "schema": { "type": "boolean" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "POI list" } }
      },
      "post": {
        "summary": "Create POI",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "categoryId", "lat", "lng"],
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "categoryId": { "type": "string" },
                  "isPublic": { "type": "boolean", "default": false },
                  "lat": { "type": "number" },
                  "lng": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/api/pois/{id}": {
      "get": {
        "summary": "Get POI details with photos and shares",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "POI detail" }, "404": { "description": "Not found" } }
      },
      "patch": {
        "summary": "Update POI",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "categoryId": { "type": "string" },
                  "isPublic": { "type": "boolean" },
                  "lat": { "type": "number" },
                  "lng": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated" }, "403": { "description": "Forbidden" } }
      },
      "delete": {
        "summary": "Archive POI",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Archived" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/pois/{id}/restore": {
      "post": {
        "summary": "Restore archived POI",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Restored" } }
      }
    },
    "/api/pois/{id}/shares": {
      "post": {
        "summary": "Share POI with specific user",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username"],
                "properties": {
                  "username": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Shared" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/pois/{id}/shares/{userId}": {
      "delete": {
        "summary": "Revoke shared access",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Revoked" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/pois/{id}/photos": {
      "post": {
        "summary": "Upload POI photo",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["photo"],
                "properties": {
                  "photo": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Photo uploaded" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/photos/{id}": {
      "get": {
        "summary": "Get photo binary",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Image" }, "404": { "description": "Not found" } }
      },
      "delete": {
        "summary": "Archive photo",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Archived" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/photos/{id}/restore": {
      "post": {
        "summary": "Restore archived photo",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Restored" }, "403": { "description": "Forbidden" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
